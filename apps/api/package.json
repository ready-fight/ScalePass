{
  "name": "@scalepass/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "dotenv -e ../../.env -- vitest run",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^10.1.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
